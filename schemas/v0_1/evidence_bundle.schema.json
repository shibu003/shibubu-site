{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "shibubu:v0.1:evidence_bundle",
    "title": "EvidenceBundle",
    "type": "object",
    "required": [
        "bundle_id",
        "bill_id",
        "claims",
        "evidence",
        "bundle_hash",
        "created_at"
    ],
    "properties": {
        "bundle_id": {
            "type": "string",
            "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "bill_id": {
            "type": "string",
            "pattern": "^bill_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "claims": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "claim_id",
                    "text",
                    "evidence_ids"
                ],
                "properties": {
                    "claim_id": {
                        "type": "string",
                        "pattern": "^claim:[0-9]+$"
                    },
                    "text": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 2000
                    },
                    "evidence_ids": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "string"
                        }
                    },
                    "assumptions": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "uncertainty": {
                        "type": "string",
                        "enum": [
                            "low",
                            "medium",
                            "high"
                        ]
                    }
                },
                "additionalProperties": false
            }
        },
        "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "evidence_id",
                    "type",
                    "excerpt",
                    "hash"
                ],
                "properties": {
                    "evidence_id": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "entry",
                            "link",
                            "memo",
                            "deepdive"
                        ]
                    },
                    "source": {
                        "type": "object",
                        "properties": {
                            "uri": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            },
                            "captured_at": {
                                "type": "string",
                                "format": "date-time"
                            }
                        },
                        "additionalProperties": false
                    },
                    "excerpt": {
                        "type": "string",
                        "minLength": 20,
                        "maxLength": 1000
                    },
                    "claims_supported": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "confidence": {
                        "type": "string",
                        "enum": [
                            "low",
                            "medium",
                            "high"
                        ]
                    },
                    "hash": {
                        "type": "string",
                        "pattern": "^(sha256|blake3):[a-f0-9]{64}$"
                    }
                },
                "additionalProperties": false
            }
        },
        "bundle_hash": {
            "type": "string",
            "pattern": "^(sha256|blake3):[a-f0-9]{64}$"
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "additionalProperties": false
}