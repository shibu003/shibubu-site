{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "shibubu:v0.1:gate_decision",
    "title": "GateDecision",
    "type": "object",
    "required": [
        "bill_id",
        "decision",
        "reason_codes",
        "rationale",
        "risk_assessment",
        "trace"
    ],
    "properties": {
        "bill_id": {
            "type": "string",
            "pattern": "^bill_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "decision": {
            "type": "string",
            "enum": [
                "PASS",
                "WARN",
                "FAIL",
                "NEEDS_MORE_EVIDENCE",
                "ESCALATE"
            ]
        },
        "reason_codes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string"
            }
        },
        "rationale": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4000
        },
        "required_followups": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "risk_assessment": {
            "type": "object",
            "required": [
                "harm",
                "deception",
                "privacy"
            ],
            "properties": {
                "harm": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ]
                },
                "deception": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ]
                },
                "privacy": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ]
                }
            },
            "additionalProperties": false
        },
        "trace": {
            "type": "object",
            "required": [
                "proposal_hash",
                "evidence_hash",
                "policy_version"
            ],
            "properties": {
                "proposal_hash": {
                    "type": "string",
                    "pattern": "^(sha256|blake3):[a-f0-9]{64}$"
                },
                "evidence_hash": {
                    "type": "string",
                    "pattern": "^(sha256|blake3):[a-f0-9]{64}$"
                },
                "policy_version": {
                    "type": "string",
                    "minLength": 1
                }
            },
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}