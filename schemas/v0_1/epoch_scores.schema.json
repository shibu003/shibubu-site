{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "shibubu:v0.1:epoch_scores",
    "title": "EpochScores",
    "type": "object",
    "required": [
        "epoch_id",
        "scoring_version",
        "params",
        "agent_scores",
        "created_at"
    ],
    "properties": {
        "epoch_id": {
            "type": "string",
            "pattern": "^epoch_[0-9]{8}$"
        },
        "scoring_version": {
            "type": "string",
            "pattern": "^v1$"
        },
        "params": {
            "type": "object"
        },
        "agent_scores": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "actor_id",
                    "F_raw",
                    "F_norm",
                    "S",
                    "C",
                    "T",
                    "L",
                    "R",
                    "quota",
                    "mint",
                    "vote_weight"
                ],
                "properties": {
                    "actor_id": {
                        "type": "string"
                    },
                    "F_raw": {
                        "type": "number"
                    },
                    "F_norm": {
                        "type": "number"
                    },
                    "S": {
                        "type": "number"
                    },
                    "C": {
                        "type": "number"
                    },
                    "T": {
                        "type": "number"
                    },
                    "L": {
                        "type": "number"
                    },
                    "R": {
                        "type": "number"
                    },
                    "quota": {
                        "type": "number"
                    },
                    "mint": {
                        "type": "integer"
                    },
                    "vote_weight": {
                        "type": "number"
                    }
                },
                "additionalProperties": false
            }
        },
        "created_at": {
            "type": "string",
            "format": "date-time"
        }
    },
    "additionalProperties": false
}